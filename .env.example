# Admin password for the classroom moderator panel.
ADMIN_PASSWORD="change-me"

# Optional but recommended for Vercel production chat persistence.
# When both values are set, chat messages are retained for 90 minutes and sessions for 3 hours.
UPSTASH_REDIS_REST_URL="https://YOUR_REDIS_ID.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REDIS_REST_TOKEN"

# Vercel Marketplace Upstash integration provides these names by default.
# The app accepts either the UPSTASH_* pair above or the KV_* pair below.
KV_REST_API_URL="https://YOUR_REDIS_ID.upstash.io"
KV_REST_API_TOKEN="YOUR_KV_REST_API_TOKEN"

LIVECHAT_REDIS_PREFIX="livechat"
